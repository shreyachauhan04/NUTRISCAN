      <aliases enabled='yes' />
      <column caption='Health Claim Flag' datatype='string' name='[Calculation_1500017679273986]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER([product_name]), &apos;protein&apos;) &#10;OR CONTAINS(LOWER([product_name]), &apos;natural&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;healthy&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;organic&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;diet&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;light&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;zero&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;multigrain&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;sugar free&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;wholegrain&apos;)&#10;THEN &quot;Has Health Claim&quot;&#10;ELSE &quot;No Claim&quot;&#10;END' />
      </column>
      <column caption='Health Claim FLag' datatype='string' name='[Calculation_1500017679392771]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER([product_name]), &apos;protein&apos;) &#10;OR CONTAINS(LOWER([product_name]), &apos;natural&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;healthy&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;organic&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;diet&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;light&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;zero&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;multigrain&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;sugar free&apos;)&#10;OR CONTAINS(LOWER([product_name]), &apos;wholegrain&apos;)&#10;THEN &quot;Has Health Claim&quot;&#10;ELSE &quot;No Claim&quot;&#10;END' />
      </column>
      <column caption='Fail Rate' datatype='real' name='[Calculation_1500017680322564]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [nutriscan_grade] = &apos;C&apos; OR [nutriscan_grade] = &apos;D&apos; &#10;OR [nutriscan_grade] = &apos;E&apos; OR [nutriscan_grade] = &apos;F&apos; &#10;THEN 1 ELSE 0 END) &#10;/ &#10;COUNT([product_name])' />
      </column>
